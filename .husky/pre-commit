#!/usr/bin/env sh
# Pre-commit liviano: solo eslint --fix de los archivos staged (ver .lintstagedrc.cjs).
# Los tests corren en pre-push (relacionados) y en CI (suite completa).
# Saltar: SKIP_PRE_COMMIT=1 git commit   ·   o   git commit --no-verify
[ -n "$SKIP_PRE_COMMIT" ] && exit 0
npx lint-staged
