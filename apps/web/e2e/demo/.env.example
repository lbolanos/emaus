# Secretos y configuración de los videos-demo. Copiá a `.env` y completá.
#   cp apps/web/e2e/demo/.env.example apps/web/e2e/demo/.env
# El `.env` real es gitignoreado. NUNCA commitees claves.

# Voz natural TTS (Deepgram Aura-2). Vacío → cae a macOS `say` (voz Paulina es-MX).
# Voces es-LATAM: aura-2-celeste-es (colombiana, clara), aura-2-selena-es (neutral),
# aura-2-estrella-es (mexicana), aura-2-javier-es (masculina).
DEEPGRAM_API_KEY=
DEEPGRAM_VOICE=aura-2-celeste-es

# Binarios de ffmpeg/ffprobe con encoder H.264/AAC (Homebrew: `brew install ffmpeg`).
# El ffmpeg que trae Playwright NO sirve para el mux final.
FFMPEG=/opt/homebrew/bin/ffmpeg
FFPROBE=/opt/homebrew/bin/ffprobe

# App real a conducir (dev). Credenciales de testing local.
DEMO_BASE_URL=http://localhost:5173
DEMO_EMAIL=leonardo.bolanos@gmail.com
DEMO_PASSWORD=123456

# ── Subida a YouTube (upload-to-youtube.mjs) ──────────────────────────────────
# Setup (una vez) en Google Cloud Console, con la cuenta del canal:
#   1. Crear proyecto → habilitar "YouTube Data API v3".
#   2. Pantalla de consentimiento OAuth → agregar tu cuenta como usuario de prueba.
#   3. Credenciales → OAuth 2.0 → tipo "App de escritorio". Copiar ID y secret aquí.
#   4. Autorizar una vez:  node e2e/demo/youtube-auth.mjs  (guarda youtube-token.json).
YT_CLIENT_ID=
YT_CLIENT_SECRET=
# Privacidad por defecto de los videos subidos: public | unlisted | private
YT_PRIVACY=public
# Categoría de YouTube (27 = Educación).
YT_CATEGORY_ID=27

# ── Gemini "nano banana" (gen-ai-image.mjs) ───────────────────────────────────
# Key gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
