# Database Configuration
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=emaus

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google reCAPTCHA Configuration
# In development, leave as placeholder to skip verification.
# In production, set your real reCAPTCHA v3 secret key.
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_V3_SECRET_KEY_HERE
# Minimum reCAPTCHA v3 score (0.0-1.0) for captcha-protected endpoints that don't
# set their own. Tunable without redeploy. Default: 0.5
# RECAPTCHA_MIN_SCORE=0.5
# Minimum score specifically for login. v3 scores legit users low for benign
# reasons, so login is more lenient than public forms. Default: 0.3
# RECAPTCHA_MIN_SCORE_LOGIN=0.3

# Application Configuration
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=your_secret_key_here
# Duración de la sesión logueada en días (rolling: cuenta desde la última actividad)
SESSION_MAX_AGE_DAYS=30
PORT=3084

# Business timezone used for calendar-absolute comparisons (e.g. deciding
# whether a retreat is past based on its endDate). Keep as America/Mexico_City
# for the Mexican deployment so evening users don't get "retreat ended"
# six hours early. Use any IANA timezone name.
APP_TIMEZONE=America/Mexico_City

# Migration Configuration
MIGRATIONS_AUTO_RUN=true
MIGRATIONS_WARN_ONLY=true
MIGRATIONS_DRY_RUN=false
MIGRATIONS_LOG_LEVEL=info
MIGRATIONS_MAX_PENDING=5

# Seed Configuration
SEED_AUTO_RUN=true
SEED_DRY_RUN=false
SEED_FORCE=false
SEED_MASTER_USER_EMAIL=admin@example.com
SEED_MASTER_USER_NAME=Administrator
SEED_MASTER_USER_PASSWORD=secure_password_here

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@emaus.com

# Candado de seguridad: fuera de producción (NODE_ENV != 'production') NUNCA se
# envían correos reales, aunque las variables SMTP de arriba estén completas.
# La DB de local/staging suele ser una copia de producción con emails reales de
# participantes; esto evita que el cron de secuencias les envíe sin querer.
# Ponlo en 'true' SOLO para forzar envíos en dev, idealmente apuntando SMTP a un
# buzón de captura local (Mailpit/Mailtrap), no a un SMTP real.
ALLOW_REAL_EMAILS=false

# Avatar Storage Configuration
# Options: base64 (store in database), s3 (AWS S3 storage)
AVATAR_STORAGE=base64

# AWS S3 Configuration (required when AVATAR_STORAGE=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=emaus-media

# S3 Storage Prefixes (for different content types)
S3_AVATARS_PREFIX=avatars/
S3_RETREAT_MEMORIES_PREFIX=retreat-memories/
S3_DOCUMENTS_PREFIX=documents/
S3_PUBLIC_ASSETS_PREFIX=public-assets/

# Legacy S3_BUCKET_PREFIX (backward compatibility)
S3_BUCKET_PREFIX=avatars/

# AI Chat Configuration (Vercel AI SDK)
# Provider: anthropic | google | openai
AI_PROVIDER=anthropic
AI_MODEL=glm-4.7
AI_CHAT_MAX_TOKENS=1024

# Anthropic (also works with Anthropic-compatible APIs like Z.ai via ANTHROPIC_BASE_URL)
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic/v1
# Google Gemini
# GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key_here
# OpenAI (also works with OpenAI-compatible APIs via OPENAI_BASE_URL)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.z.ai/api/paas/v4

# ── Auditoría de dominio (escrituras de participantes, mesas, camas, pagos, retiros) ──
# Dos sinks: tabla domain_audit_log (DB) + archivo NDJSON rotado. Ambos activos por defecto.
# AUDIT_DB_ENABLED=false        # desactiva el sink a base de datos
# AUDIT_FILE_ENABLED=false      # desactiva el sink a archivo
# Directorio de los NDJSON. Default: prod → /var/log/emaus, dev → apps/api/logs
# AUDIT_LOG_DIR=/var/log/emaus
# Retención (winston-daily-rotate-file): días ('90d') o número de archivos.
AUDIT_LOG_RETENTION_DAYS=90d
# Tamaño máximo por archivo antes de rotar.
AUDIT_LOG_MAX_SIZE=20m
