# Database Configuration
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=emaus

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google reCAPTCHA Configuration
# Demo keys for development (always return valid score)
# Site key: 6Lf_NUssAAAAAOrGCI__EA8t9mU_8F9XITgG4_3M
# Secret key: 6Lf_NUssAAAAAJNezAhbH6Ym26f8qA6ac4pGGXAe
RECAPTCHA_SECRET_KEY=6Lf_NUssAAAAAJNezAhbH6Ym26f8qA6ac4pGGXAe

# Application Configuration
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=your_secret_key_here
PORT=3001

# Migration Configuration
MIGRATIONS_AUTO_RUN=true
MIGRATIONS_WARN_ONLY=true
MIGRATIONS_DRY_RUN=false
MIGRATIONS_LOG_LEVEL=info
MIGRATIONS_MAX_PENDING=5

# Seed Configuration
SEED_AUTO_RUN=true
SEED_DRY_RUN=false
SEED_FORCE=false
SEED_MASTER_USER_EMAIL=admin@example.com
SEED_MASTER_USER_NAME=Administrator
SEED_MASTER_USER_PASSWORD=secure_password_here

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@emaus.com

# Avatar Storage Configuration
# Options: base64 (store in database), s3 (AWS S3 storage)
AVATAR_STORAGE=base64

# AWS S3 Configuration (required when AVATAR_STORAGE=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=emaus-media

# S3 Storage Prefixes (for different content types)
S3_AVATARS_PREFIX=avatars/
S3_RETREAT_MEMORIES_PREFIX=retreat-memories/
S3_DOCUMENTS_PREFIX=documents/
S3_PUBLIC_ASSETS_PREFIX=public-assets/

# Legacy S3_BUCKET_PREFIX (backward compatibility)
S3_BUCKET_PREFIX=avatars/

# AI Chat Configuration (Vercel AI SDK)
# Provider: anthropic | google | openai
AI_PROVIDER=anthropic
AI_MODEL=glm-4.7
AI_CHAT_MAX_TOKENS=1024

# Anthropic (also works with Anthropic-compatible APIs like Z.ai via ANTHROPIC_BASE_URL)
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic/v1
# Google Gemini
# GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key_here
# OpenAI (also works with OpenAI-compatible APIs via OPENAI_BASE_URL)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.z.ai/api/paas/v4
